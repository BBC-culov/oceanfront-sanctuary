# Bazhouse — Apache config for Hostinger (SPA React Router)

# ---------------------------------------------------------------
# 1. Force HTTPS + non-www → bazhouse.com (canonico)
# ---------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.bazhouse\.com$ [NC]
  RewriteRule ^ https://bazhouse.com%{REQUEST_URI} [L,R=301]

  # ---------------------------------------------------------------
  # 2. SPA fallback — tutte le rotte non-file servono index.html
  # ---------------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# ---------------------------------------------------------------
# 3. Compressione GZIP
# ---------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ---------------------------------------------------------------
# 4. Cache headers
# ---------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Asset con hash (Vite) — cache lunghissima
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|jpg|jpeg|png|webp|avif|gif|ico|mp4|webm)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML + sitemap + robots — sempre freschi
  <FilesMatch "\.(html|xml|txt|json)$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------
# 5. Security headers
# ---------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ---------------------------------------------------------------
# 6. MIME types corretti
# ---------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType image/avif .avif
  AddType font/woff2 .woff2
  AddType application/manifest+json .webmanifest
</IfModule>

# ---------------------------------------------------------------
# 7. Blocca accesso a file sensibili
# ---------------------------------------------------------------
<FilesMatch "(^\.|\.env|\.git|package(-lock)?\.json|composer\.(json|lock)|yarn\.lock|bun\.lockb)$">
  Require all denied
</FilesMatch>

# Disabilita directory listing
Options -Indexes

# Default document
DirectoryIndex index.html
